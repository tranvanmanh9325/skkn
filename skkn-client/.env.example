# URL của Express backend — dùng trong fetch() phía client
NEXT_PUBLIC_API_URL=http://localhost:5000

# Bí mật ký JWT — PHẢI khớp hoàn toàn với biến cùng tên trong Express backend .env
# Không được prefix NEXT_PUBLIC_ vì secret này chỉ dùng trong Middleware (server-side Edge)
JWT_ACCESS_SECRET=your-super-secret-jwt-key-min-32-chars
