{
  "name": "skkn-api-main",
  "version": "1.0.0",
  "description": "SKKN Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run seed:admin && npm run seed:master && npm run seed:records && npm run seed:subjects-detailed && ts-node-dev --respawn --transpile-only -r dotenv/config src/server.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/scripts/seedAdmin.js && node -r dotenv/config dist/scripts/seedMasterData.js && node -r dotenv/config dist/scripts/seedRecords.js && node -r dotenv/config dist/scripts/seedSubjectsDetailed.js && node dist/server.js",
    "seed:admin": "ts-node -r dotenv/config src/scripts/seedAdmin.ts",
    "seed:master": "ts-node -r dotenv/config src/scripts/seedMasterData.ts",
    "seed:records": "ts-node -r dotenv/config src/scripts/seedRecords.ts",
    "seed:subjects-detailed": "ts-node -r dotenv/config src/scripts/seedSubjectsDetailed.ts",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cloudinary": "^2.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "socket.io": "^4.8.1",
    "tesseract.js": "^6.0.1",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.5.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
